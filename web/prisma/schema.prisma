// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ATHLETE
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum Discipline {
  RUNNING
  CYCLING
  SWIMMING
  TRIATHLON
}

enum SubmissionStatus {
  PENDING_AUTO_CHECK
  PENDING_MANUAL_REVIEW
  VERIFIED
  REJECTED
}

enum VerificationMode {
  AUTO
  SEMI_AUTO
  MANUAL
}

enum ReviewDecision {
  APPROVED
  REJECTED
  NEEDS_INFO
}

enum EntityStatus {
  PENDING
  ACTIVE
  ARCHIVED
}

enum SubmissionType {
  CREATE
  UPDATE
  DELETE
}

enum BenchmarkSource {
  PROTOCOL
  ADMIN
  ATHLETE_HINT
}

enum ProposalType {
  COMPETITION
  CLUB
  COACH
  ATHLETE_LINK
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

enum TelegramDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id              String              @id @default(cuid())
  email           String?             @unique
  passwordHash String?
  telegramId      String?             @unique
  role            UserRole            @default(ATHLETE)
  athlete         Athlete?
  reviews         ManualReview[]
  auditLogs       AuditLog[]
  magicLinkTokens MagicLinkToken[]
  proposals       EntityProposal[]    @relation("ProposalAuthor")
  reviewedProposals EntityProposal[]  @relation("ProposalReviewer")
  telegramConversations TelegramConversation[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Athlete {
  id               String             @id @default(cuid())
  userId           String             @unique
  firstName        String
  lastName         String
  middleName       String?
  publicDisplayName String?
  showPublicResults Boolean           @default(false)
  telegramUsername String?
  showTelegramProfile Boolean         @default(false)
  birthDate        DateTime
  gender           Gender
  city             String?
  seasonAgeGroup   String?
  status           EntityStatus       @default(ACTIVE)
  archivedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions      ResultSubmission[]
  verifiedResults  VerifiedResult[]
  rankingEntries   RankingEntry[]
  clubs            AthleteClub[]
  coaches          AthleteCoach[]
  telegramLinkRequests AthleteLinkRequest[] @relation("RequestedAthlete")
  candidateLinkRequests AthleteLinkRequest[] @relation("CandidateAthlete")
}

model Season {
  id              String             @id @default(cuid())
  name            String             @unique
  startDate       DateTime
  endDate         DateTime
  status          SeasonStatus       @default(DRAFT)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  submissions     ResultSubmission[]
  verifiedResults VerifiedResult[]
  rankingEntries  RankingEntry[]
  scoreRules      ScoreRule[]
}

model EventCategory {
  id                String      @id @default(cuid())
  discipline        Discipline
  categoryKey       String
  label             String
  basePointsDefault Int
  description       String?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  events            Event[]
  scoreRules        ScoreRule[]
  verifiedResults   VerifiedResult[]

  @@unique([discipline, categoryKey])
}

model Series {
  id           String        @id @default(cuid())
  name         String        @unique
  websiteUrl   String?
  status       EntityStatus  @default(ACTIVE)
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  competitions Competition[]
}

model Competition {
  id              String        @id @default(cuid())
  name            String
  eventDate       DateTime
  city            String?
  pageUrl         String?
  registrationUrl String?
  resultsUrl      String?
  seriesId        String?
  status          EntityStatus  @default(ACTIVE)
  archivedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  series          Series?       @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  distances       Event[]

  @@index([eventDate, status])
  @@index([seriesId])
}

model Event {
  id              String             @id @default(cuid())
  competitionId   String?
  name            String
  eventDate       DateTime
  discipline      Discipline
  distanceLabel   String
  sourceUrl       String?
  location        String?
  categoryId      String?
  status          EntityStatus       @default(ACTIVE)
  archivedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  competition     Competition?       @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  category        EventCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  protocolRows    EventProtocolRow[]
  protocolGroups  ProtocolGroup[]
  submissions     ResultSubmission[]
  verifiedResults VerifiedResult[]

  @@index([eventDate, discipline])
  @@index([competitionId])
}

model EventProtocolRow {
  id                  String    @id @default(cuid())
  eventId             String
  athleteNameRaw      String
  gender              Gender?
  ageGroupRaw         String?
  finishTimeRaw       String
  finishTimeSeconds   Int?
  placementOverall    Int?
  placementInAgeGroup Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  event               Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ProtocolGroup {
  id                    String          @id @default(cuid())
  eventId               String
  groupKey              String
  label                 String
  gender                Gender?
  minAge                Int?
  maxAge                Int?
  fifthPlaceTimeSeconds Int?
  benchmarkSource       BenchmarkSource?
  benchmarkNotes        String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  event                 Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, groupKey])
  @@index([eventId])
}

model ResultSubmission {
  id                String           @id @default(cuid())
  athleteId         String
  seasonId          String
  eventId           String?
  submissionType    SubmissionType   @default(CREATE)
  targetVerifiedResultId String?
  eventNameRaw      String
  eventDate         DateTime
  discipline        Discipline
  distanceLabel     String
  ageGroupClaimed   String
  finishTimeRaw     String
  finishTimeSeconds Int
  proposedFifthPlaceTimeSeconds Int?
  protocolUrl       String?
  placementOverall  Int?
  placementInAgeGroup Int?
  bibNumber         String?
  comment           String?
  status            SubmissionStatus @default(PENDING_MANUAL_REVIEW)
  adminNotes        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  athlete           Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  season            Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  event             Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  verifiedResult    VerifiedResult?
  targetVerifiedResult VerifiedResult? @relation("TargetVerifiedResult", fields: [targetVerifiedResultId], references: [id], onDelete: SetNull)
  reviews           ManualReview[]

  @@index([athleteId, seasonId, status])
  @@index([targetVerifiedResultId])
}

model VerifiedResult {
  id                   String           @id @default(cuid())
  athleteId            String
  seasonId             String
  submissionId         String           @unique
  eventId              String
  eventCategoryId      String?
  ageGroupUsed         String
  fifthPlaceTimeSeconds Int
  lagPercent           Decimal
  awardedPoints        Int
  verificationMode     VerificationMode
  scoreRuleId          String
  status               EntityStatus     @default(ACTIVE)
  archivedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  athlete              Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  season               Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  submission           ResultSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  event                Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventCategory        EventCategory?   @relation(fields: [eventCategoryId], references: [id], onDelete: SetNull)
  scoreRule            ScoreRule        @relation(fields: [scoreRuleId], references: [id], onDelete: Restrict)
  changeRequests       ResultSubmission[] @relation("TargetVerifiedResult")
}

model Club {
  id           String        @id @default(cuid())
  name         String
  websiteUrl   String?
  status       EntityStatus  @default(ACTIVE)
  mergedIntoId String?
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  athletes     AthleteClub[]

  @@unique([name])
  @@index([status])
}

model Coach {
  id           String        @id @default(cuid())
  name         String
  websiteUrl   String?
  status       EntityStatus  @default(ACTIVE)
  mergedIntoId String?
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  athletes     AthleteCoach[]

  @@unique([name])
  @@index([status])
}

model AthleteClub {
  athleteId String
  clubId    String
  createdAt DateTime @default(now())
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@id([athleteId, clubId])
  @@index([clubId])
}

model AthleteCoach {
  athleteId String
  coachId   String
  createdAt DateTime @default(now())
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@id([athleteId, coachId])
  @@index([coachId])
}

model EntityProposal {
  id             String         @id @default(cuid())
  type           ProposalType
  status         ProposalStatus @default(PENDING)
  proposerUserId String?
  reviewerUserId String?
  targetEntityId String?
  payloadJson    Json
  reviewNotes    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  proposer       User?          @relation("ProposalAuthor", fields: [proposerUserId], references: [id], onDelete: SetNull)
  reviewer       User?          @relation("ProposalReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([type, status])
}

model AthleteLinkRequest {
  id                 String         @id @default(cuid())
  telegramId         String
  telegramUsername   String?
  requestedAthleteId String?
  candidateAthleteId String?
  profileJson        Json
  status             ProposalStatus @default(PENDING)
  reviewNotes        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  requestedAthlete   Athlete?       @relation("RequestedAthlete", fields: [requestedAthleteId], references: [id], onDelete: SetNull)
  candidateAthlete   Athlete?       @relation("CandidateAthlete", fields: [candidateAthleteId], references: [id], onDelete: SetNull)

  @@index([telegramId, status])
}

model TelegramConversation {
  id         String   @id @default(cuid())
  telegramId String   @unique
  chatId     String
  userId     String?
  state      String
  dataJson   Json?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model TelegramUpdate {
  id         String   @id @default(cuid())
  updateId   String   @unique
  receivedAt DateTime @default(now())
  handledAt  DateTime?
}

model TelegramNotification {
  id          String                 @id @default(cuid())
  telegramId  String
  chatId      String
  text        String
  status      TelegramDeliveryStatus @default(PENDING)
  attempts    Int                    @default(0)
  lastError   String?
  sentAt      DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status, createdAt])
}

model ScoreRule {
  id              String           @id @default(cuid())
  seasonId        String
  discipline      Discipline
  categoryKey     String
  eventCategoryId String?
  basePoints      Int
  formulaVersion  String           @default("v1")
  activeFrom      DateTime?
  activeTo        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  season          Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  eventCategory   EventCategory?   @relation(fields: [eventCategoryId], references: [id], onDelete: SetNull)
  verifiedResults VerifiedResult[]

  @@index([seasonId, discipline, categoryKey])
}

model RankingEntry {
  id                String    @id @default(cuid())
  athleteId         String
  seasonId          String
  totalPoints       Int       @default(0)
  rank              Int
  scoredResultsCount Int      @default(0)
  snapshotAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  athlete           Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  season            Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([athleteId, seasonId])
  @@index([seasonId, rank])
}

model ManualReview {
  id            String           @id @default(cuid())
  submissionId  String
  reviewerId    String
  decision      ReviewDecision
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  submission    ResultSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer      User             @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  entityType  String
  entityId    String
  action      String
  payloadJson Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
