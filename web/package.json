{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "prestart": "npm run prisma:generate",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "admin:hash-password": "node scripts/hash-admin-password.mjs",
    "deploy:check": "node scripts/check-deploy-readiness.mjs",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:push": "prisma db push --accept-data-loss --config prisma.config.ts",
    "db:status": "prisma migrate status --config prisma.config.ts",
    "db:reset": "prisma migrate reset --force",
    "db:seed:demo": "node scripts/seed-demo.mjs",
    "db:baseline:postgres": "mkdir -p prisma/postgres && prisma migrate diff --config prisma.config.ts --from-empty --to-schema-datamodel prisma/schema.prisma --script --output prisma/postgres/baseline.sql",
    "db:smoke:postgres": "npm run prisma:generate && node scripts/check-postgres-runtime.mjs",
    "db:status:postgres": "prisma migrate status --config prisma.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:generate:postgres": "prisma generate",
    "prisma:validate:postgres": "prisma validate --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
