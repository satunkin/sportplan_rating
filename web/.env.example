# ----------------------------------------
# Base app
# ----------------------------------------

NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"
SESSION_SECRET="replace-with-a-long-random-secret"

# ----------------------------------------
# Database
# ----------------------------------------
# Preferred runtime URL for the app.
# For hosted/serverless environments use the Supabase transaction pooler / pgbouncer-style URL.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Preferred direct connection for Prisma CLI / migrations.
# If your local environment cannot reach the IPv6-only direct host,
# use the Supabase session pooler on port 5432 here instead.
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Transitional fallback while moving older commands/envs onto DATABASE_URL + DIRECT_URL.
# Can point to Supabase session pooler or direct connection.
DATABASE_URL_POSTGRES="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# ----------------------------------------
# Magic link email delivery
# ----------------------------------------
# In local/dev mode, if SMTP is empty, the app shows a direct preview link.
# Optional for the Telegram-first production flow.
# Configure SMTP only if the legacy athlete magic-link login must remain usable.

EMAIL_FROM="SportPlan Rating <no-reply@example.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# ----------------------------------------
# Admin auth
# ----------------------------------------

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="paste-output-from-npm-run-admin-hash-password"

# Temporary local/dev fallback only.
ADMIN_ACCESS_KEY="cyclon-admin-dev"

# ----------------------------------------
# Telegram bot
# ----------------------------------------

# Token from @BotFather. Never expose it to the browser.
TELEGRAM_BOT_TOKEN=""

# Random secret sent by Telegram in x-telegram-bot-api-secret-token.
TELEGRAM_WEBHOOK_SECRET="replace-with-a-long-random-secret"

# Public bot link used by the participation page, for example https://t.me/cyclon_rating_bot.
NEXT_PUBLIC_TELEGRAM_BOT_URL=""
