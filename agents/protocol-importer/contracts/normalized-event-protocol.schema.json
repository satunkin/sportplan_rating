{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyclon.local/schemas/normalized-event-protocol.schema.json",
  "title": "NormalizedEventProtocol",
  "type": "object",
  "required": [
    "organizer",
    "sourceUrl",
    "eventName",
    "eventDate",
    "distanceLabel",
    "rows"
  ],
  "properties": {
    "organizer": {
      "type": "string",
      "minLength": 1
    },
    "sourceUrl": {
      "type": "string",
      "minLength": 1
    },
    "eventName": {
      "type": "string",
      "minLength": 1
    },
    "eventDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "location": {
      "type": "string"
    },
    "distanceLabel": {
      "type": "string",
      "minLength": 1
    },
    "rowCount": {
      "type": "integer",
      "minimum": 0
    },
    "extractedAt": {
      "type": "string"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "athleteNameRaw",
          "finishTimeRaw"
        ],
        "properties": {
          "placeOverall": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "placeAgeGroup": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "athleteNameRaw": {
            "type": "string",
            "minLength": 1
          },
          "country": {
            "type": "string"
          },
          "ageGroupRaw": {
            "type": "string"
          },
          "genderRaw": {
            "type": "string"
          },
          "bibNumber": {
            "type": "string"
          },
          "paceRaw": {
            "type": "string"
          },
          "finishTimeRaw": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

