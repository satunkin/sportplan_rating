{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyclon.local/schemas/protocol-import-request.schema.json",
  "title": "ProtocolImportRequest",
  "type": "object",
  "required": [
    "organizer",
    "sourceUrl",
    "discipline",
    "eventName",
    "eventDate",
    "distanceLabel",
    "normalizedProtocolPath"
  ],
  "properties": {
    "organizer": {
      "type": "string",
      "minLength": 1
    },
    "sourceUrl": {
      "type": "string",
      "minLength": 1
    },
    "discipline": {
      "type": "string",
      "enum": [
        "RUNNING",
        "CYCLING",
        "SWIMMING",
        "TRIATHLON"
      ]
    },
    "eventName": {
      "type": "string",
      "minLength": 1
    },
    "eventDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "location": {
      "type": "string"
    },
    "distanceLabel": {
      "type": "string",
      "minLength": 1
    },
    "normalizedProtocolPath": {
      "type": "string",
      "minLength": 1
    },
    "replaceExistingRows": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

